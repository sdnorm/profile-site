<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Spencer Norman — Rails Developer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "Spencer Norman — seasoned Ruby on Rails developer. Scrappy, detail-oriented, ships code worth being proud of." %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= render "shared/fonts" %>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body data-site="<%= current_site %>" data-controller="notification">
    <%= render "shared/flash" %>
    <%= yield %>
  </body>
</html>
