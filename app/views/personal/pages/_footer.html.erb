<%# Footer — mark, social icon buttons, colophon %>
<footer style="background: var(--surface-page); border-top: 1px solid var(--border-subtle);">
  <div style="max-width: var(--container); margin: 0 auto; padding: 32px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;">
    <div style="display: flex; align-items: center; gap: 11px;">
      <%= image_tag "mark.svg", width: 28, height: 28, alt: "" %>
      <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted);">© <%= Time.current.year %> Spencer Norman</span>
    </div>
    <div style="display: flex; gap: 6px;">
      <a class="sn-iconbtn sn-iconbtn--md" aria-label="GitHub" title="GitHub" href="https://github.com/sdnorm" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.6 2 12.2c0 4.5 2.9 8.3 6.8 9.6.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.4-3.4-1.4-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.6-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.3 9.3 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.6 5 .4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5 4-1.3 6.8-5.1 6.8-9.6C22 6.6 17.5 2 12 2z"/></svg>
      </a>
      <a class="sn-iconbtn sn-iconbtn--md" aria-label="LinkedIn" title="LinkedIn" href="#">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5a2.5 2.5 0 0 0 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05C20.3 8.65 21 11 21 14.1V21h-4v-6.2c0-1.48-.03-3.38-2.06-3.38-2.06 0-2.38 1.6-2.38 3.27V21H9z"/></svg>
      </a>
      <a class="sn-iconbtn sn-iconbtn--md" aria-label="X" title="X" href="#">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-7.5 8.6L23 22h-6.6l-5.2-6.8L5.3 22H2.2l8-9.2L1.5 2h6.8l4.7 6.2zm-1.1 18h1.7L7.2 3.8H5.4z"/></svg>
      </a>
      <a class="sn-iconbtn sn-iconbtn--md" aria-label="Email" title="Email" href="mailto:spencernorman@hey.com">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
      </a>
    </div>
  </div>
</footer>
