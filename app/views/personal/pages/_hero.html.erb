<%# Hero — typographic headline, subhead, CTAs, and a "currently" panel %>
<section id="top" style="max-width: var(--container); margin: 0 auto; padding: 84px 32px 72px;">
  <div class="sn-hero-grid" style="display: grid; grid-template-columns: 1.35fr 1fr; gap: 56px; align-items: center;">
    <div>
      <span class="sn-eyebrow"><span class="sn-eyebrow__rule"></span>Software · Business · Product</span>
      <h1 style="font-family: var(--font-display); font-weight: 800; letter-spacing: -0.035em;
                 line-height: 1.02; font-size: clamp(40px, 6vw, 72px); color: var(--text-strong); margin: 22px 0 0;">
        Software that<br>moves the business <span style="background: linear-gradient(transparent 62%, var(--honey-300) 62%);">forward</span>.
      </h1>
      <p style="font-size: 18px; line-height: 1.55; color: var(--text-body); max-width: 44ch; margin: 24px 0 0;">
        I'm Spencer — a developer who thinks in P&amp;L as much as pull requests. I build the product, then make it pay. Sixteen years turning code into revenue.
      </p>
      <div style="display: flex; gap: 14px; align-items: center; margin-top: 34px; flex-wrap: wrap;">
        <a href="#work" class="sn-btn sn-btn--primary sn-btn--lg"><span>See selected work</span></a>
        <a href="#contact" class="sn-btn sn-btn--ghost sn-btn--lg">
          <span>Get in touch</span>
          <span class="sn-btn__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </a>
      </div>
      <div style="display: flex; gap: 44px; margin-top: 52px;">
        <div>
          <div style="font-family: var(--font-display); font-weight: 800; font-size: 30px; letter-spacing: -0.03em; color: var(--text-strong); line-height: 1;">16 yrs</div>
          <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-top: 7px;">Shipping product</div>
        </div>
        <div>
          <div style="font-family: var(--font-display); font-weight: 800; font-size: 30px; letter-spacing: -0.03em; color: var(--text-strong); line-height: 1;">$40M+</div>
          <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-top: 7px;">Revenue influenced</div>
        </div>
        <div>
          <div style="font-family: var(--font-display); font-weight: 800; font-size: 30px; letter-spacing: -0.03em; color: var(--text-strong); line-height: 1;">3</div>
          <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-top: 7px;">Exits</div>
        </div>
      </div>
    </div>

    <div class="sn-card sn-card--inverse sn-card--pad" style="padding: 28px;">
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <span style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--honey-300);">Currently</span>
        <span style="font-family: var(--font-mono); font-size: 11px; color: var(--ink-300);">2026</span>
      </div>
      <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 22px; letter-spacing: -0.02em; color: var(--paper-50); margin: 16px 0 8px;">
        Founding Engineer, Ledgerline
      </h3>
      <p style="font-size: 14.5px; line-height: 1.55; color: var(--ink-300); margin: 0;">
        Building the billing engine behind a fintech doing $9M ARR. Zero to one on infra, pricing, and the team.
      </p>
      <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 20px;">
        <span class="sn-tag sn-tag--filled" style="color: var(--paper-50); background: rgba(255,255,255,0.08);">TypeScript</span>
        <span class="sn-tag sn-tag--filled" style="color: var(--paper-50); background: rgba(255,255,255,0.08);">Stripe</span>
        <span class="sn-tag sn-tag--filled" style="color: var(--paper-50); background: rgba(255,255,255,0.08);">Postgres</span>
      </div>
    </div>
  </div>
</section>
