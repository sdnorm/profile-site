<%# Hero — typographic headline, subhead, CTAs, and a "currently" panel %>
<section id="top" style="max-width: var(--container); margin: 0 auto; padding: 84px 32px 72px;">
  <div class="sn-hero-grid" style="display: grid; grid-template-columns: 1.35fr 1fr; gap: 56px; align-items: center;">
    <div>
      <span class="sn-eyebrow"><span class="sn-eyebrow__rule"></span>Staff Engineer · Ruby on Rails</span>
      <h1 style="font-family: var(--font-display); font-weight: 800; letter-spacing: -0.035em;
                 line-height: 1.02; font-size: clamp(40px, 6vw, 72px); color: var(--text-strong); margin: 22px 0 0;">
        Complex workflows,<br>made <span style="background: linear-gradient(transparent 62%, var(--honey-300) 62%);">simple</span>.
      </h1>
      <p style="font-size: 18px; line-height: 1.55; color: var(--text-body); max-width: 46ch; margin: 24px 0 0;">
        I'm Spencer, a staff-level engineer with 11+ years building and leading Ruby on Rails apps. I love the majestic monolith: cohesive, server-rendered Rails with Hotwire, plus the data-intensive backends behind it. I also know different problems call for different tools, so I reach for what fits rather than forcing a favorite. At my best, I turn complicated, high-stakes workflows into software that feels simple.
      </p>
      <div style="display: flex; gap: 14px; align-items: center; margin-top: 34px; flex-wrap: wrap;">
        <a href="#work" class="sn-btn sn-btn--primary sn-btn--lg"><span>See my work</span></a>
        <a href="#contact" class="sn-btn sn-btn--ghost sn-btn--lg">
          <span>Get in touch</span>
          <span class="sn-btn__i"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </a>
      </div>
      <div style="display: flex; gap: 44px; margin-top: 52px;">
        <div>
          <div style="font-family: var(--font-display); font-weight: 800; font-size: 30px; letter-spacing: -0.03em; color: var(--text-strong); line-height: 1;">11+ yrs</div>
          <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-top: 7px;">On Ruby on Rails</div>
        </div>
        <div>
          <div style="font-family: var(--font-display); font-weight: 800; font-size: 30px; letter-spacing: -0.03em; color: var(--text-strong); line-height: 1;">Millions</div>
          <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-top: 7px;">Users served</div>
        </div>
        <div>
          <div style="font-family: var(--font-display); font-weight: 800; font-size: 30px; letter-spacing: -0.03em; color: var(--text-strong); line-height: 1;">9,800+</div>
          <div style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-top: 7px;">Locations scaled</div>
        </div>
      </div>
    </div>

    <div class="sn-card sn-card--inverse sn-card--pad" style="padding: 28px;">
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <span style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--honey-300);">Currently</span>
        <span style="font-family: var(--font-mono); font-size: 11px; color: var(--ink-300);">2026</span>
      </div>
      <h3 style="font-family: var(--font-display); font-weight: 700; font-size: 22px; letter-spacing: -0.02em; color: var(--paper-50); margin: 16px 0 8px;">
        Software Engineer, Nava PBC
      </h3>
      <p style="font-size: 14.5px; line-height: 1.55; color: var(--ink-300); margin: 0;">
        Building features end-to-end on the HealthCare.gov Marketplace — a Rails platform serving millions of users through open enrollment.
      </p>
      <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-top: 20px;">
        <span class="sn-tag sn-tag--filled" style="color: var(--paper-50); background: rgba(255,255,255,0.08);">Ruby on Rails</span>
        <span class="sn-tag sn-tag--filled" style="color: var(--paper-50); background: rgba(255,255,255,0.08);">React</span>
        <span class="sn-tag sn-tag--filled" style="color: var(--paper-50); background: rgba(255,255,255,0.08);">TypeScript</span>
      </div>
    </div>
  </div>
</section>
